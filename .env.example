# Environment Variables Configuration
# Copy this file to .env and customize the values for your local environment
# The .env file is not version controlled and contains user-specific settings

# ============================================================================
# Configuration Settings
# ============================================================================

# Config file to use (without .toml extension)
# Available options: python_personal, python_repo, python_local
# Default: python_personal
ENV_CONFIG=python_personal

# Logger configuration to use (without .toml extension)
# Available options: logger_console, logger_file, logger_file_console,
#                    logger_file_limit, logger_file_limit_console
# Default: logger_file_limit_console
ENV_LOGGER=logger_file_limit_console

# Flag for running unit tests (True/False)
# Default: False
ENV_RUNNING_UNIT_TESTS=False

# ============================================================================
# Healthcheck Configuration (Optional)
# ============================================================================

# Healthchecks.io ping URLs for heartbeat monitoring (JSON format)
# Each entry maps a key to a unique ping URL. Workers and watchdogs reference
# their endpoint by key via the healthcheck_url_key field in the watchdog config.
# HEALTHCHECK_PING_URL='[{"key": "default", "url": "https://hc-ping.com/uuid1"}, {"key": "worker_a", "url": "https://hc-ping.com/uuid2"}]'

# ============================================================================
# Additional Environment Variables (Optional)
# ============================================================================
# Add your custom environment variables below:
# DATABASE_PASSWORD=your_password_here
# API_KEY=your_api_key_here
# DEBUG_MODE=False

